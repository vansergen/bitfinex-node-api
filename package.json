{
  "name": "bitfinex-node-api",
  "version": "4.0.0",
  "description": "Bitfinex Node.js API",
  "exports": {
    ".": "./dist/index.js"
  },
  "directories": {
    "test": "test"
  },
  "engines": {
    "node": ">=24.16.0",
    "npm": ">=11.13.0"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:remove": "rm -rf dist",
    "ci:all": "npm ci && npm run prettier && npm run eslint && npm run commitlint && npm test && npm publish --dry-run && npm run docs:build && npm run coverage",
    "commitlint": "commitlint --verbose --from=dc2607d7549e61b3c7710c0efd9e3532b07e8c82",
    "coverage": "mkdir -p coverage && node --import=tsx --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info **/*.test.ts",
    "docs:build": "typedoc",
    "eslint": "eslint --no-warn-ignored **/*.ts",
    "eslint:fix": "npm run eslint -- --fix",
    "install:clean": "npm install",
    "postbuild": "prettier -c -w dist",
    "postdocs:build": "prettier -c -w docs",
    "postpublish": "npm run build:remove",
    "prebuild": "npm run build:remove",
    "preinstall:clean": "rm -rf node_modules package-lock.json",
    "prepare": "husky",
    "prepublishOnly": "npm run build",
    "prettier": "prettier -c .",
    "prettier:write": "prettier -c -w .",
    "preversion": "npm run docs:build",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vansergen/bitfinex-node-api.git"
  },
  "keywords": [
    "Bitfinex",
    "crypto",
    "exchange",
    "API"
  ],
  "author": "Sergey Bakulin <sergey.bakulin.github@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/vansergen/bitfinex-node-api/issues"
  },
  "homepage": "https://github.com/vansergen/bitfinex-node-api#readme",
  "dependencies": {
    "rpc-request": "^10.0.0"
  },
  "devDependencies": {
    "@binden/commitlint-config": "^3.0.0",
    "@binden/eslint-config-ts": "^6.0.1",
    "@binden/semantic-release-config": "^3.0.4",
    "@binden/tsconfig": "^4.0.1",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "ws": "^8.21.0"
  }
}
